{
  "crons": [
    {
      "path": "/api/cron/reminders",
      "schedule": "*/15 * * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "bugs.(?<domain>.*)"
        }
      ],
      "destination": "/devlog"
    }
  ]
}
