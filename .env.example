# Travel CMS Environment Variables
# Copy this file to .env.local and fill in your values

# ===================
# Supabase
# ===================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# For migrations: Project Settings > Database > Connection string (URI)
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ===================
# AI (Optional - enables AI features)
# ===================
# OpenAI API Key - get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Anthropic API Key (future) - get from https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...

# ===================
# Auth JWT Secrets (Required in production)
# ===================
# Generate strong random strings for all three client JWT secrets
CLIENT_JWT_ACCESS_SECRET=replace-with-random-64-char-string
CLIENT_JWT_REFRESH_SECRET=replace-with-random-64-char-string
CLIENT_JWT_INVITATION_SECRET=replace-with-random-64-char-string

# Superadmin JWT secret (or set JWT_SECRET for legacy fallback)
SUPERADMIN_JWT_SECRET=replace-with-random-64-char-string

# App-level encryption key for company secrets at rest.
# Use exactly 32 bytes (raw) or base64-encoded 32-byte key.
APP_DATA_ENCRYPTION_KEY=replace-with-base64-32-byte-key

# ===================
# Email (Optional - for sending invoices, check-in notifications)
# Uses Resend: https://resend.com - get API key from https://resend.com/api-keys
# ===================
# RESEND_API_KEY=re_...
# Optional: sender address (must be verified in Resend). Default: Travel CMS <noreply@travel-cms.com>
# EMAIL_FROM=Your Company <invoices@yourdomain.com>

# ===================
# External APIs (Optional)
# ===================
# Flight status API
# FLIGHTAWARE_API_KEY=...

# Google Maps (for transfer duration and trip map)
# GOOGLE_MAPS_API_KEY=...
# Client-side Google Maps (for trip map display)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=...

# Weather API
# OPENWEATHER_API_KEY=...
