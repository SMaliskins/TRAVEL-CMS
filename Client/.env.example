# Local `expo start` only. Cloud builds: set the same keys in expo.dev → Project → Environment variables.
EXPO_PUBLIC_API_URL=https://your-production-cms.example.com

# Optional: same as Expo Project ID if you do not commit it in app.config.ts
# EXPO_PUBLIC_EAS_PROJECT_ID=

# Optional: minimal influencer-only shell (also available via eas profile `referral`)
# EXPO_PUBLIC_CLIENT_APP_REFERRAL_ONLY=1
