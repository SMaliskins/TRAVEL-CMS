# Base URL of the Next.js app (no trailing slash). For real phones this MUST be your deployed HTTPS
# URL (e.g. Vercel), not localhost — see Client/docs/PRODUCTION_DEPLOYMENT.md
EXPO_PUBLIC_API_URL=https://your-domain.com

# When 1 or true: after login only the Referral screen is shown (influencer / early access builds)
# EXPO_PUBLIC_CLIENT_APP_REFERRAL_ONLY=1

# EAS cloud builds: set EXPO_PUBLIC_API_URL (and optional flags) in expo.dev → Project → Environment variables
# for each build profile; do not rely on this file on CI unless your workflow loads it.
